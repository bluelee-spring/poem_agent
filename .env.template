# 诗千家 API 配置
POEM_BASE_URL=https://poem.pkudh.org
POEM_ACCESS_TOKEN=your_bearer_token_here

# LLM Provider 配置
# 可选值: deepseek, openai
LLM_PROVIDER=deepseek
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Agent 参数
N_CANDIDATES=3
QUALITY_THRESHOLD=0.6
MAX_RETRIES=2

# 日志
LOG_LEVEL=INFO
LOG_FILE=data/app.log

#飞书机器人配置
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=

FEISHU_FORWARD_CHAT_ID=
FEISHU_WIKI_URL=